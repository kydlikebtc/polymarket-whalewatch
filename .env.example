# Telegram is OPTIONAL. Leave both blank to run the alert engine in record-only
# mode (matches are written to data.sqlite and shown on the 实时告警 dashboard).
# Set BOTH to also push matches to a Telegram channel.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=
LARGE_THRESHOLDS=10000,50000
POLL_INTERVAL_MS=4000
# Optional: point the engine + dashboard at a non-default SQLite file.
# DASH_DB=data.sqlite
